model Question {
    id         String  @id @default(uuid())
    product_id String
    product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
    askedById  String
    askedBy    User    @relation(fields: [askedById], references: [id])

    question  String
    answer    String?
    createdAt DateTime @default(now())
}
