model User {
    id        String     @id @default(uuid())
    name      String
    role      Role       @default(CUSTOMER)
    email     String     @unique
    password  String
    phone     String     @unique
    photo     String?
    createdAt DateTime   @default(now())
    addresses Address[]
    cart      Cart?
    wishlist  Wishlist?
    questions Question[]
    reviews   Review[]
}
